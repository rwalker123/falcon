}

table KnowledgeTimelineEventState {
  tick:ulong;
  kind:KnowledgeTimelineEventKind;
  sourceFaction:uint;
  deltaPercent:short;
  noteHandle:string;
}

table KnowledgeMetricsState {
  leakWarnings:uint;
  leakCriticals:uint;
  countermeasuresActive:uint;
  commonKnowledgeTotal:uint;
}

table CrisisTrendSample {
  tick:ulong;
  value:float;
}

table CrisisGaugeState {
  kind:CrisisMetricKind;
  raw:float;
  ema:float;
  trend5t:float;
  warnThreshold:float;
  criticalThreshold:float;
  lastUpdatedTick:ulong;
  staleTicks:ulong;
  band:CrisisSeverityBand;
  history:[CrisisTrendSample];
}

table CrisisTelemetryState {
  gauges:[CrisisGaugeState];
  modifiersActive:uint;
  foreshockIncidents:uint;
  containmentIncidents:uint;
  warningsActive:uint;
  criticalsActive:uint;
}

table CrisisOverlayAnnotationState {
  label:string;
  severity:CrisisSeverityBand;
  path:[uint];
}

table CrisisOverlayState {
  heatmap:ScalarRaster;
  annotations:[CrisisOverlayAnnotationState];
}

table TileState {
  entity:ulong;
  x:uint;
  y:uint;
  element:ubyte;
  mass:long;
  temperature:long;
  terrain:TerrainType;
  terrainTags:ushort;
  cultureLayer:uint;
  mountainKind:MountainKind = None;
  mountainRelief:float = 1.0;
  // Tile-intrinsic per-turn morale drain (fixed-point, FIXED_POINT_SCALE = 1e6; >= 0, bigger =
  // harsher). Band-independent property of the place — the sim's `tile_morale_pressure` total.
  habitability:long = 0;
  // Packed per-side river classes: 2 bits per odd-r direction (0=E,1=SE,2=SW,3=W,4=NW,5=NE),
  // decoded via RiverClass (0=None, 1=Minor, 2=Major; 3 reserved). Both hexes flanking a river
  // edge carry it on their own side. With TerrainType.NavigableRiver this fully determines the
  // river render — there is no separate polyline overlay.
  riverEdges:ushort = 0;
  // Packed per-CORNER river inflow: 2 bits per hex corner (0=lower-right, 1=bottom, 2=lower-left,
  // 3=upper-left, 4=top, 5=upper-right — screen space, +y down; corner i at angle 60*i + 30),
  // decoded via RiverClass exactly like riverEdges. Set only on the FIRST hex of a NavigableRiver
  // chain, at the corner where the edge-river chain terminates and hands its water to the trunk,
  // carrying the class of the last edge it emitted. An edge river ends at a vertex, never mid-side,
  // so this is the point the renderer joins the tributary to the trunk hex. 0 everywhere else.
  riverInflow:ushort = 0;
}

table LogisticsLinkState {
  entity:ulong;
  from:ulong;
  to:ulong;
  capacity:long;
  flow:long;
}

// A band's resolved settlement-progression stage — how rooted-in-place its dwelling has become.
// Fully data-driven: the sim resolves which stage a band is in from the ORDERED stage list in
// `settlement_stage_config.json` and ships the winning stage's presentation tokens here. All three
// fields are opaque pass-through strings the sim never interprets (`icon` is an emoji today, a
// sprite/asset key later). Adding a stage is a pure config edit — no schema, sim, or client change.
table SettlementStageView {
  id:string;     // stable stage id (e.g. "nomadic" | "camp" | "village")
  label:string;  // human-readable stage name for tooltips
  icon:string;   // opaque presentation token (emoji now, asset key later)
}

table PopulationCohortState {
  entity:ulong;
  home:ulong;
  currentX:uint;
  currentY:uint;
  isTraveling:bool;
  size:uint;
  morale:long;
  generation:ushort;
  faction:uint;
  knowledgeFragments:[KnownTechFragment];
  migration:PendingMigration;
  harvestTask:HarvestTask;
  scoutTask:ScoutTask;
  accessibleStockpile:AccessibleStockpile;
  children:long = 0;
  working:long = 0;
  elders:long = 0;
  stores:[CohortStore];
  ageTurns:uint = 0;
  daysOfFood:float = 0;
  activity:string;
  supplyNetworkId:uint = 0;
  // This turn's signed morale delta (fixed-point, FIXED_POINT_SCALE = 1e6) — trend arrow source.
  moraleDelta:long = 0;
  // Dominant negative morale driver when falling: 0=None, 1=Terrain, 2=Cold, 3=Unrest.
  moraleCause:ubyte = 0;
  // Civilization Wellbeing (docs/plan_civ_wellbeing.md). All fixed-point (FIXED_POINT_SCALE = 1e6)
  // except the two head-counts. Derived per-turn unless noted.
  // Productivity modifier stack result (`output = base × Π(modifiers)`): 1e6 = 100% output.
  outputMultiplier:long = 1000000;
  // Discontented share of the band this turn, 0..1 (1e6 = fully discontented).
  discontentFraction:long = 0;
  // People who emigrated from / immigrated into this band last turn (discontent-driven migration).
  lastEmigrated:uint = 0;
  lastImmigrated:uint = 0;
  // Severity × duration grievance accumulator (reserved for a future revolution consequence;
  // Phase 1 only surfaces it). PERSISTED for rollback (unlike the other derived fields here).
  grievance:long = 0;
  // Layer-1 named morale contributions whose signed sum IS moraleDelta (the itemized breakdown):
  // settling (base growth, ≥0), terrain/climate (≤0), unrest (signed).
  moraleSettling:long = 0;
  moraleTerrain:long = 0;
  moraleClimate:long = 0;
  moraleUnrest:long = 0;
  // Band's live hunt sub-mode summary: the take policy of the largest Hunt assignment
  // (sustain|surplus|market|eradicate); empty string when not hunting. Appended last (see
  // append-only schema discipline). Client labels the cancel affordance from it.
  huntMode:string;
  // Early-Game Labor (slice 3a): the band's per-source labor allocation — one entry per staffed
  // Forage tile / Hunt herd / Scout / Warrior demand. Client renders the allocation panel from it;
  // also the rollback-persisted staffing. Appended last (append-only schema discipline).
  laborAssignments:[LaborAssignment];
  // Whole working-age workers left unassigned (idle: eat but produce nothing). Derived.
  idleWorkers:uint = 0;
  // Whole assignable working-age workers this band supplies (the Σ-invariant ceiling). Derived.
  workingAge:uint = 0;
  // Band's Chebyshev work radius (LaborConfig.band_work_range) — client draws the work-range ring.
  // Global config today (same every band); surfaced per-band so the client reads it off the
  // selected band. Appended last (append-only schema discipline).
  workRange:uint = 0;
  // Band's effective scout vantage distance — how far the forward-observer vantage ring is posted
  // out from the band (min(vantage_distance_base + scouts * vantage_distance_per_scout,
  // vantage_distance_max) from LaborConfig.scout), 0 with no scouts. Field name retained for wire
  // compat; scouts now reveal by posting vantage points that see around obstacles, not a flat ring.
  scoutRevealRadius:uint = 0;
  // Expedition discriminators (docs/plan_exploration_and_sites.md §2). A detached scouting party is
  // a PopulationCohort tagged `Expedition`; these fields are false/""/empty for a normal band.
  // Client-facing: distinct marker glyph/label + awaiting-orders marker state + a Recall affordance.
  isExpedition:bool = false;
  expeditionMission:string;   // "scout" | "hunt"; empty for normal bands.
  expeditionPhase:string;     // "outbound"|"awaiting"|"returning"|"hunting"|"delivering"; empty for normal bands.
  // Persistence-only (rollback restores an in-flight expedition + its unreported findings):
  homeBandEntity:ulong = 0;   // the real band that outfitted this party (entity bits).
  expeditionAnnounced:bool = false; // whether the arrival feed line has fired for this AwaitingOrders latch.
  pendingRevealX:[uint];      // observed-but-unreported tile coords (zipped with pendingRevealY).
  pendingRevealY:[uint];
  // Server-side hard cap on an expedition party (expedition_config.json max_party_size). A global
  // config lever echoed per-cohort (same idiom as workRange) so the client outfit stepper pre-clamps
  // to min(idle_workers, this). Populated for every cohort (the stepper is on the resident-band panel).
  maxExpeditionPartySize:uint = 0;
  // The band's resolved settlement-progression stage (data-driven; see `SettlementStageView`).
  // The sim resolves it from the band's `size` against the ordered `settlement_stage_config.json`
  // list (interim: a size-only proxy; Phase 3/4 enrich the resolution inputs without touching this
  // field or the client). Client draws `icon` directly and shows `label` in the tooltip. Appended
  // last (append-only schema discipline).
  settlementStage:SettlementStageView;
  // Hunt expedition only: carry cap = party_workers × expedition_config.hunt.per_worker_carry (the
  // provisions ceiling the party fills to before auto-Delivering). Capture-only, `0` for scouts +
  // normal bands. The client shows carried/cap (carried = stores/daysOfFood) + a FULL state.
  expeditionCarryCap:float = 0;
  // Hunt mission only: the target herd id (`HerdRegistry` fauna_id). Empty for scout/normal bands.
  // A string (not uint) because herd ids are non-numeric (e.g. "herd_3_00") — matches
  // LaborAssignment.faunaId. Persisted so a rollback reconstructs `Hunt { fauna_id }`. Appended last
  // (append-only schema discipline — must follow every field shipped in earlier PRs).
  expeditionTargetHerd:string;
  // Hunt mission only: the take policy (sustain|surplus|market|eradicate; mirrors huntMode). Empty
  // for scout/normal bands. Persisted so a rollback reconstructs `Hunt { fauna_id, policy }`; drives
  // the client's per-policy behaviour label + policy picker default. Appended last.
  expeditionHuntPolicy:string;
  // The `move_band`/`BandTravel` destination tile while traveling (`isTraveling` gates it; `0,0`
  // when not traveling). Lets the client draw a destination hex + line from a selected band or
  // expedition to where it's headed. Appended last (append-only schema discipline).
  travelTargetX:uint = 0;
  travelTargetY:uint = 0;
  // Band's effective hunt reach = LaborConfig `band_work_range + hunt_leash_tiles` (the same leash a
  // Hunt assignment lapses past). Echoed per-cohort like `workRange` so the client can offer a local
  // hunt vs a hunting expedition based on the clicked herd's distance. Appended last (append-only).
  huntReach:uint = 0;
  // Band-level per-turn food flow (derived at capture). foodIncome = Σ of every worked source's
  // actualYield (the per-source breakdown summed); foodConsumption = food_demand(children, working,
  // elders) (the one-turn demand daysOfFood divides by). Client draws a food-ledger footer from these
  // without re-summing the assignment rows. Appended last (append-only schema discipline).
  foodIncome:float = 0;
  foodConsumption:float = 0;
}

// One staffed labor demand in a band's allocation (Early-Game Labor, slice 3a).
table LaborAssignment {
  kind:string;       // "forage" | "hunt" | "scout" | "warrior"
  workers:uint = 0;
  targetX:uint = 0;  // Forage tile / Hunt herd position readout
  targetY:uint = 0;
  faunaId:string;    // Hunt target herd id
  policy:string;     // Hunt take policy (sustain|surplus|market|eradicate)
  // Per-source food-income breakdown (derived per-turn at capture, 0 on a rehydrated save before the
  // next tick). actualYield = provisions this source produced this turn; sustainableYield = what it
  // could yield without drawing down its stock (forage: ≡ actual; hunt: herd net regrowth). A per-turn
  // actualYield > sustainableYield is the client-derived overhunting signal. Appended (append-only).
  actualYield:float = 0;
  sustainableYield:float = 0;
  // Minimum workers that would have produced this turn's take = the overstaffing signal. workers >
  // workersNeeded ⇒ the binding constraint was not labor, so the extra workers were idle (client
  // flags the wasted labor). 0 when the source produced nothing; a tended patch / corralled herd
  // (maintenance labor) reports 1. Derived per-turn at capture (0 on a rehydrated save before the
  // next tick). Appended (append-only).
  workersNeeded:uint = 0;
}

// One commodity entry in a band's local goods store (fixed-point quantity, `Scalar::SCALE` = 1.0).
table CohortStore {
  item:string;
  quantity:long = 0;
}

table PendingMigration {
